PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/discord_analytics
DATABASE_POOL_MAX=20
JWT_SECRET=replace_me_with_at_least_32_characters
OAUTH_STATE_SECRET=replace_me_with_at_least_32_characters
SESSION_COOKIE_NAME=analytics_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_PATH=/
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=auto
SESSION_TTL_DAYS=30
DISCORD_CLIENT_ID=replace
DISCORD_CLIENT_SECRET=replace
DISCORD_REDIRECT_URI=http://localhost:4000/api/auth/discord/callback
WEB_APP_URL=http://localhost:4173
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173
INTERNAL_API_SECRET=replace
BOT_CONTROL_URL=http://localhost:4100
CRON_TIMEZONE=UTC
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=0
INTERNAL_REQUEST_TIMEOUT_MS=5000
INTERNAL_REQUEST_RETRIES=2
