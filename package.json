{
  "name": "discord-activity-analytics-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:bot": "npm --workspace apps/bot run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "local:db:start": "powershell -ExecutionPolicy Bypass -File ./scripts/local-postgres.ps1 start",
    "local:db:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/local-postgres.ps1 stop",
    "local:db:status": "powershell -ExecutionPolicy Bypass -File ./scripts/local-postgres.ps1 status",
    "lint": "npm --workspaces --if-present run lint",
    "start:api": "npm --workspace apps/api run start",
    "start:bot": "npm --workspace apps/bot run start",
    "start:worker": "npm --workspace apps/worker run start",
    "start:web": "npm --workspace apps/web run start",
    "test": "npm --workspaces --if-present run test"
  }
}
